# ============================================================
# OVERSEER BOT AI - ENVIRONMENT VARIABLES TEMPLATE
# ============================================================
# ⚠️ THIS IS A TEMPLATE FILE - DO NOT PUT ACTUAL SECRETS HERE!
# ⚠️ This .env.example file IS committed to Git for reference
# 
# TO USE THIS TEMPLATE:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your ACTUAL secret values
# 3. The .env file is in .gitignore and will NOT be committed
# 4. NEVER commit actual secrets to version control!
# 
# For cloud deployment (Render, Heroku, etc.):
# - Set environment variables in your platform's dashboard
# - Do NOT commit secrets in render.yaml or similar files
# ============================================================

# ------------------------------------------------------------
# TWITTER / X API CREDENTIALS  (all 5 required)
# ------------------------------------------------------------
# Where to get these:
#   1. Go to https://developer.twitter.com/
#   2. Create a Project and an App
#   3. Set App permissions to "Read and Write"
#   4. After saving permissions, regenerate your Access Token / Secret
#      (old tokens keep the old permission level)
#
# CONSUMER_KEY      — "API Key" shown on the App's "Keys and tokens" page
# CONSUMER_SECRET   — "API Key Secret" shown on the same page
# ACCESS_TOKEN      — "Access Token" (user-level, tied to your account)
# ACCESS_SECRET     — "Access Token Secret" (paired with ACCESS_TOKEN)
# BEARER_TOKEN      — App-only read token; shown on "Keys and tokens" page
#
# Tier notes:
#   Free tier  → write-only (no @mention reads, no search/retweet)
#   Basic tier → read + write → enables @mention replies and retweet hunting
CONSUMER_KEY=your_api_key_here
CONSUMER_SECRET=your_api_key_secret_here
ACCESS_TOKEN=your_access_token_here
ACCESS_SECRET=your_access_token_secret_here
BEARER_TOKEN=your_bearer_token_here

# ------------------------------------------------------------
# ADMIN AUTHENTICATION  (Monitoring UI)
# ------------------------------------------------------------
# Protects the dashboard at http://your-host:5000
# Generate a strong password: openssl rand -base64 32
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_something_secure

# ------------------------------------------------------------
# AI / LLM CONFIGURATION  (at least one enables AI-generated tweets)
# ------------------------------------------------------------
# ── PRIMARY: xAI (Grok) — recommended ───────────────────────
# Get your key at https://console.x.ai/
# When set, Grok is used first. Other providers only activate if Grok fails.
XAI_API=your_xai_api_key_here
XAI_MODEL=grok-3-mini

# ── FALLBACK 1: OpenAI (or any OpenAI-compatible provider) ──
# Get your key at https://platform.openai.com/api-keys
# Works with Groq, Together.ai, and local Ollama by changing OPENAI_BASE_URL
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ── FALLBACK 2: Hugging Face ─────────────────────────────────
# Get your token at https://huggingface.co/settings/tokens
# Free tier available — used as last-resort fallback
HUGGING_FACE_TOKEN=your_hugging_face_token_here
HF_MODEL=HuggingFaceH4/zephyr-7b-beta

# ------------------------------------------------------------
# SERVER CONFIGURATION
# ------------------------------------------------------------
# Port the Flask web server listens on (default 5000)
PORT=5000

# Public URL of this service — used for the Render.com keep-alive ping
# Set to your Render/Heroku/Railway URL (e.g. https://your-app.onrender.com)
RENDER_EXTERNAL_URL=

# ------------------------------------------------------------
# OPTIONAL: WALLET FEATURES
# ------------------------------------------------------------
ENABLE_WALLET_UI=true

# Solana configuration
SOLANA_PRIVATE_KEY=your_solana_private_key_here
SOLANA_RPC_ENDPOINT=https://api.mainnet-beta.solana.com

# Ethereum/BSC configuration
ETH_PRIVATE_KEY=your_ethereum_private_key_here
ETH_RPC_ENDPOINT=https://ethereum.publicnode.com
BSC_RPC_ENDPOINT=https://bsc-dataseed1.binance.org

# ------------------------------------------------------------
# OPTIONAL: EXTERNAL INTEGRATIONS
# ------------------------------------------------------------
# Secures incoming webhooks at POST /overseer-event
# Generate with: openssl rand -hex 32
WEBHOOK_API_KEY=your_webhook_api_key_here

# External dashboard / API polling (leave blank if not used)
OVERSEER_BOT_AI_URL=your_bot_url_here
OVERSEER_BOT_AI_API_KEY=your_api_key_here
